# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Build/distribution artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test/tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDE/editor settings
.vscode/
.idea/

# Local agent/editor settings
.claude/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Runtime/generated app outputs
audio_out/
screenshots/

# Local profile/runtime state (keep folder, ignore contents by default)
profiles/*.json
!profiles/.gitkeep

# Logs/temp
*.log
*.tmp
*.temp



